[sub_resource type="GDScript" id="GDScript_qs0rr"]
script/source = "extends Node2D

@onready var animated_sprite = $AnimatedSprite2D
@onready var area = $Area2D

var cherry = 1  # How much gold this coin gives

func _ready():
	# Play coin animation
	animated_sprite.play(\"Idle\")  # Change to your animation name
	
	# Connect the area signal
	area.body_entered.connect(_on_body_entered)

func _on_body_entered(body):
	if body.name == \"Player\":
		collect_cherry(body)

func collect_cherry(player):
	print(\"🍒 Cherry collected! Cherry: \", Game.gold, \" → \", Game.cherry + cherry)
	
	# Add gold
	animated_sprite.play(\"Collect\")
	Game.gold += cherry
	
	# Save game
	Utilities.saveGame()
	
	# Play sound effect
	AudioController.play_coin_collect()
	
	# Optional: Play collect animation/effect before disappearing
	await get_tree().create_timer(0.1).timeout
	
	# Remove coin
	queue_free()
"

