[sub_resource type="GDScript" id="GDScript_k6ns5"]
script/source = "extends CanvasLayer
@onready var coins_label = $Panel/CoinLabel
@onready var cherries_label = $Panel/CherriesLabel
@onready var gems_label = $Panel/GemsLabel
@onready var score_label = $Panel/ScoreLabel
@onready var completion_label = $Panel/CompletionLabel
@onready var time_label = $Panel/TimeLabel
@onready var total_label = $Panel/TotalLabel
@onready var continue_button = $Panel/ContinueButton

var coins_collected = 0
var cherries_collected = 0
var gems_collected = 0
var current_score = 0
var bonus_score = 0

# Total collectibles in the level
var total_coins = 0
var total_cherries = 0
var total_gems = 0

var next_level_scene = \"\"

func _ready() -> void:
	# Get the stats from Game
	coins_collected = Game.gold
	cherries_collected = Game.cherry
	gems_collected = Game.gem
	current_score = Game.score
	
	# Get totals from Game (these should be set when level loads)
	total_coins = Game.total_coins_in_level
	total_cherries = Game.total_cherries_in_level
	total_gems = Game.total_gems_in_level
	
	# Hide continue button initially
	continue_button.visible = false
	
	# Start the tally animation
	start_tally()

func start_tally():
	# Play level clear sound
	AudioController.play_level_complete()
	
	# Fade out music smoothly
	var music_player = AudioController.get_node(\"Music\")
	if music_player:
		var fade_tween = create_tween()
		fade_tween.tween_property(music_player, \"volume_db\", -80, 1.5)
		await fade_tween.finished
		AudioController.stop_music()
		music_player.volume_db = 0
	else:
		AudioController.stop_music()
	
	# Set initial values to 0 with totals
	coins_label.text = \"Coins: 0 / \" + str(total_coins)
	cherries_label.text = \"Cherries: 0 / \" + str(total_cherries)
	gems_label.text = \"Gems: 0 / \" + str(total_gems)
	score_label.text = \"Score: 0\"
	completion_label.text = \"Completion: 0%\"
	time_label.text = \"Time: 0:00\"  # ← Add this!
	total_label.text = \"TOTAL: 0\"
	
	await get_tree().create_timer(0.5).timeout
	
	# Count up coins
	await count_up(coins_label, \"Coins: \", coins_collected, 0, total_coins)
	bonus_score += coins_collected * 100
	
	await get_tree().create_timer(0.3).timeout
	
	# Count up cherries
	await count_up(cherries_label, \"Cherries: \", cherries_collected, 0, total_cherries)
	bonus_score += cherries_collected * 500
	
	await get_tree().create_timer(0.3).timeout
	
	# Count up gems
	await count_up(gems_label, \"Gems: \", gems_collected, 0, total_gems)
	bonus_score += gems_collected * 1000
	
	await get_tree().create_timer(0.3).timeout

	# Count up score FIRST
	await count_up_score(score_label, \"Score: \", current_score, 0)

	await get_tree().create_timer(0.3).timeout

	# THEN calculate and show completion percentage
	var total_collectibles = total_coins + total_cherries + total_gems + Game.total_enemies_in_level
	var collected_items = coins_collected + cherries_collected + gems_collected + Game.enemies_killed
	var completion_percentage = 0

	if total_collectibles > 0:
		completion_percentage = int((float(collected_items) / float(total_collectibles)) * 100)
		# Cap at 100% maximum
		completion_percentage = min(completion_percentage, 100)

	# Animate completion percentage on the COMPLETION label
	await count_up_percentage(completion_label, \"Completion: \", completion_percentage, 0)
	
	await get_tree().create_timer(0.3).timeout
	
	# Show time taken
	show_time_taken()
	
	# Check if PERFECT and show text
	if completion_percentage >= 100:
		show_perfect_text()

	await get_tree().create_timer(0.5).timeout

	# Show total with fanfare
	var final_total = current_score + bonus_score
	Game.score = final_total
	Utilities.saveGame()
	
	total_label.modulate = Color(1, 0.84, 0)
	await count_up(total_label, \"TOTAL: \", final_total, 0)
	
	# Flash the total
	var flash_tween = create_tween()
	flash_tween.set_loops(3)
	flash_tween.tween_property(total_label, \"scale\", Vector2(1.2, 1.2), 0.2)
	flash_tween.tween_property(total_label, \"scale\", Vector2(1.0, 1.0), 0.2)
	
	await flash_tween.finished
	
	# Show continue button
	continue_button.visible = true
	AudioController.play_success()

func show_time_taken():
	var total_seconds = int(Game.level_completion_time)
	var minutes = total_seconds / 60
	var seconds = total_seconds % 60
	
	time_label.text = \"Time: %d:%02d\" % [minutes, seconds]

func show_perfect_text():
	# Create a label for the floating \"PERFECT!\" text
	var label = Label.new()
	label.text = \"PERFECT!\"
	
	# Load custom font
	var custom_font = load(\"res://RETRO_SPACE/RETRO_SPACE_INV.ttf\")
	label.add_theme_font_override(\"font\", custom_font)
	label.add_theme_font_size_override(\"font_size\", 24)
	label.modulate = Color(1.0, 0.843, 0.0, 1.0)  # Gold color
	
	# Add outline for better visibility
	label.add_theme_color_override(\"font_outline_color\", Color.BLACK)
	label.add_theme_constant_override(\"outline_size\", 3)
	
	# Add to scene and position near completion label
	add_child(label)
	label.position = completion_label.position + Vector2(150, 0)  # Adjust as needed
	
	# Play special sound
	AudioController.play_perfect_sound()  # Or use a special \"perfect\" sound
	
	# Animate: float up and fade out
	var tween = create_tween()
	tween.tween_property(label, \"position:y\", label.position.y - 40, 2.0)
	tween.parallel().tween_property(label, \"modulate:a\", 0.0, 2.0)
	
	# Remove after animation
	tween.tween_callback(label.queue_free)
	
func count_up_percentage(label: Label, prefix: String, target: int, start: int = 0):
	var duration = 1.0
	var steps = 30
	var increment = float(target - start) / steps
	
	for i in range(steps + 1):
		var current_value = int(start + increment * i)
		label.text = prefix + str(current_value) + \"%\"
		
		await get_tree().create_timer(duration / steps).timeout

func count_up(label: Label, prefix: String, target: int, start: int = 0, total: int = 0):
	var duration = 1.0
	var steps = 30
	var increment = float(target - start) / steps
	
	for i in range(steps + 1):
		var current_value = int(start + increment * i)
		
		# Show with total if provided
		if total > 0:
			label.text = prefix + str(current_value) + \" / \" + str(total)
		else:
			label.text = prefix + str(current_value)
		
		await get_tree().create_timer(duration / steps).timeout

func count_up_score(label: Label, prefix: String, target: int, start: int = 0):
	var duration = 1.0
	var steps = 30
	var increment = float(target - start) / steps
	
	for i in range(steps + 1):
		var current_value = int(start + increment * i)
		label.text = prefix + str(current_value)
		
		await get_tree().create_timer(duration / steps).timeout

func set_next_level(scene_path: String):
	next_level_scene = scene_path

func _on_continue_button_pressed() -> void:
	AudioController.select_sound()
	
	# Clear checkpoint for new level
	Game.checkpoint_position = Vector2.ZERO
	
	if next_level_scene != \"\":
		get_tree().change_scene_to_file(next_level_scene)
	else:
		get_tree().change_scene_to_file(\"res://main.tscn\")
		
func _on_continue_button_mouse_entered() -> void:
	AudioController.hover_button()

func _input(event: InputEvent) -> void:
	if event.is_action_pressed(\"ui_accept\") and continue_button.visible:
		_on_continue_button_pressed()
"

