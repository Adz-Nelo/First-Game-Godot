[sub_resource type="GDScript" id="GDScript_yx0jh"]
script/source = "extends Node2D

var player

func _ready() -> void:
	await get_tree().process_frame
	
	player = get_tree().get_first_node_in_group(\"player\")
	
	if player:
		# Check if there's a saved checkpoint in Game
		if Game.checkpoint_position != Vector2.ZERO:
			player.global_position = Game.checkpoint_position
			print(\"🔄 Respawned at checkpoint:\", Game.checkpoint_position)
		else:
			print(\"✅ No checkpoint, starting at default position\")
"

