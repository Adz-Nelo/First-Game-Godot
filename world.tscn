[sub_resource type="GDScript" id="GDScript_036b0"]
script/source = "extends Control

# Heart settings
@export var initial_max_hearts = 3  # Starting number of hearts to display
@export var heart_spacing = 25  # Space between hearts
@export var shake_intensity = 10.0  # How much the heart shakes
@export var shake_duration = 0.3  # Duration of shake animation
@export var flash_duration = 0.3  # Duration of flash effect
@export var damage_color = Color(2.0, 0.3, 0.3, 1.0)  # Bright red flash color on damage
@export var heal_color = Color(0.3, 2.5, 0.3, 1.0)  # Bright green flash color on heal

# Heart scenes (you can use TextureRect or AnimatedSprite2D)
var heart_scene = preload(\"res://health.tscn\")  # Your heart scene
var hearts = []
var previous_hp = 0
var max_hearts = 3  # Current max hearts displayed

func _ready() -> void:
	max_hearts = initial_max_hearts
	create_hearts()
	previous_hp = Game.playerHP

func _process(delta: float) -> void:
	# Check if we need more hearts
	if Game.playerHP > max_hearts:
		add_more_hearts(Game.playerHP - max_hearts)
	
	update_hearts()

func create_hearts():
	# Clear existing hearts
	for heart in hearts:
		heart.queue_free()
	hearts.clear()
	
	# Create heart containers
	for i in range(max_hearts):
		var heart = heart_scene.instantiate()
		add_child(heart)
		
		# Position hearts horizontally
		heart.position = Vector2(i * heart_spacing, 0)
		
		hearts.append(heart)

func add_more_hearts(count: int):
	# Add additional hearts dynamically
	for i in range(count):
		var heart = heart_scene.instantiate()
		add_child(heart)
		
		# Position new heart
		var index = max_hearts + i
		heart.position = Vector2(index * heart_spacing, 0)
		
		hearts.append(heart)
	
	max_hearts += count
	print(\"💚 Added\", count, \"more hearts! Total:\", max_hearts)

func update_hearts():
	var current_hp = Game.playerHP
	var hearts_to_show = int(ceil(current_hp / 1.0))  # 1 HP per heart
	
	# Check if player took damage
	if current_hp < previous_hp:
		var lost_heart_index = hearts_to_show  # The heart that just became empty
		if lost_heart_index < hearts.size():
			animate_heart_loss(hearts[lost_heart_index])
		shake_all_hearts()
	
	# Check if player healed
	if current_hp > previous_hp:
		var healed_heart_index = hearts_to_show - 1  # The heart that just became full
		if healed_heart_index >= 0 and healed_heart_index < hearts.size():
			animate_heart_gain(hearts[healed_heart_index])
	
	previous_hp = current_hp
	
	for i in range(hearts.size()):
		var heart = hearts[i]
		
		if i < hearts_to_show:
			# Full heart
			if heart.has_node(\"AnimatedSprite2D\"):
				heart.get_node(\"AnimatedSprite2D\").play(\"Heart\")
		else:
			# Empty heart
			if heart.has_node(\"AnimatedSprite2D\"):
				heart.get_node(\"AnimatedSprite2D\").play(\"Empty Heart\")

func animate_heart_gain(heart: Node):
	# Flash effect when gaining a heart
	var sprite = heart.get_node(\"AnimatedSprite2D\") if heart.has_node(\"AnimatedSprite2D\") else null
	if sprite:
		print(\"💚 Healing heart!\")  # Debug
		
		# Green healing flash
		var color_tween = create_tween()
		color_tween.tween_property(sprite, \"modulate\", heal_color, 0.1)  # Bright green
		color_tween.tween_property(sprite, \"modulate\", Color(2.0, 2.5, 2.0, 1.0), 0.1)  # Light green
		color_tween.tween_property(sprite, \"modulate\", Color(1, 1, 1, 1), 0.2)  # Back to normal
		
		# Scale pulse effect
		var transform_tween = create_tween()
		transform_tween.set_parallel(true)
		transform_tween.tween_property(heart, \"scale\", Vector2(1.4, 1.4), 0.15)
		transform_tween.tween_property(heart, \"rotation\", deg_to_rad(10), 0.15)
		transform_tween.chain().set_parallel(true)
		transform_tween.tween_property(heart, \"scale\", Vector2(1.0, 1.0), 0.2)
		transform_tween.tween_property(heart, \"rotation\", 0, 0.2)

func animate_heart_loss(heart: Node):
	# Flash effect with color distortion
	var sprite = heart.get_node(\"AnimatedSprite2D\") if heart.has_node(\"AnimatedSprite2D\") else null
	if sprite:
		print(\"Animating heart loss - applying color!\")  # Debug
		
		# Color distortion sequence: Red -> Yellow -> Red -> White -> Normal
		var color_tween = create_tween()
		color_tween.tween_property(sprite, \"modulate\", Color(2.5, 0.2, 0.2, 1.0), 0.08)  # Bright red
		color_tween.tween_property(sprite, \"modulate\", Color(2.5, 2.5, 0.2, 1.0), 0.08)  # Yellow flash
		color_tween.tween_property(sprite, \"modulate\", Color(2.5, 0.3, 2.5, 1.0), 0.08)  # Magenta
		color_tween.tween_property(sprite, \"modulate\", Color(0.2, 2.5, 2.5, 1.0), 0.08)  # Cyan glitch
		color_tween.tween_property(sprite, \"modulate\", Color(2.0, 2.0, 2.0, 1.0), 0.06)  # White
		color_tween.tween_property(sprite, \"modulate\", Color(1, 1, 1, 1), 0.12)  # Back to normal
		
		# Scale pulse effect with rotation distortion
		var transform_tween = create_tween()
		transform_tween.set_parallel(true)
		transform_tween.tween_property(heart, \"scale\", Vector2(1.6, 1.6), 0.1)
		transform_tween.tween_property(heart, \"rotation\", deg_to_rad(15), 0.1)
		transform_tween.chain().set_parallel(true)
		transform_tween.tween_property(heart, \"scale\", Vector2(0.9, 0.9), 0.15)
		transform_tween.tween_property(heart, \"rotation\", deg_to_rad(-10), 0.15)
		transform_tween.chain().set_parallel(true)
		transform_tween.tween_property(heart, \"scale\", Vector2(1.0, 1.0), 0.2)
		transform_tween.tween_property(heart, \"rotation\", 0, 0.2)

func shake_all_hearts():
	for heart in hearts:
		shake_heart(heart)
		flash_heart_color(heart)

func shake_heart(heart: Node):
	var original_pos = heart.position
	var tween = create_tween()
	
	# Create random shake offsets
	var shake_count = 6
	for i in range(shake_count):
		var offset = Vector2(
			randf_range(-shake_intensity, shake_intensity),
			randf_range(-shake_intensity, shake_intensity)
		)
		tween.tween_property(heart, \"position\", original_pos + offset, shake_duration / shake_count)
	
	# Return to original position
	tween.tween_property(heart, \"position\", original_pos, shake_duration / shake_count)

func flash_heart_color(heart: Node):
	# Add a distorted color flash to all hearts on damage
	var sprite = heart.get_node(\"AnimatedSprite2D\") if heart.has_node(\"AnimatedSprite2D\") else null
	if sprite:
		print(\"Flashing heart color!\")  # Debug
		var color_tween = create_tween()
		# Rapid color distortion with stronger colors
		color_tween.tween_property(sprite, \"modulate\", Color(3.0, 0.2, 0.2, 1.0), 0.05)  # Intense Red
		color_tween.tween_property(sprite, \"modulate\", Color(0.2, 3.0, 3.0, 1.0), 0.05)  # Cyan glitch
		color_tween.tween_property(sprite, \"modulate\", Color(3.0, 3.0, 0.2, 1.0), 0.05)  # Yellow
		color_tween.tween_property(sprite, \"modulate\", Color(3.0, 0.2, 3.0, 1.0), 0.05)  # Magenta
		color_tween.tween_property(sprite, \"modulate\", Color(1, 1, 1, 1), 0.2)  # Back to normal
		
		# Add slight rotation wobble to all hearts
		var wobble_tween = create_tween()
		wobble_tween.tween_property(heart, \"rotation\", deg_to_rad(5), 0.08)
		wobble_tween.tween_property(heart, \"rotation\", deg_to_rad(-5), 0.08)
		wobble_tween.tween_property(heart, \"rotation\", 0, 0.1)
"

[sub_resource type="GDScript" id="GDScript_ioo17"]
script/source = "extends Control

func _ready() -> void:
	# Quick outline - 4 directions
	var offsets = [
		Vector2(1, 0),   # Right
		Vector2(-1, 0),  # Left
		Vector2(0, 1),   # Down
		Vector2(0, -1)   # Up
	]
	
	for offset in offsets:
		var outline = $Label.duplicate()
		outline.modulate = Color.BLACK
		outline.position += offset * 1  # 2 pixel outline
		outline.z_index = $Label.z_index - 1
		add_child(outline)
	
	# Set main label color
	$Label.modulate = Color.WHITE  # Your text color
	$Label.z_index = 100  # Bring to front
"

[sub_resource type="GDScript" id="GDScript_gbfbk"]
script/source = "extends Label

# Called when the node enters the scene tree for the first time.
func _ready() -> void:
	pass

# Called every frame. 'delta' is the elapsed time since the previous frame.
func _process(delta: float) -> void:
	# Convert gold to whole number before displaying
	var whole_gold = int(Game.gold)  # or ceil(), floor(), round()
	text = \" \" + str(whole_gold)
"

