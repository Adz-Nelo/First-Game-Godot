[sub_resource type="GDScript" id="GDScript_41pc5"]
script/source = "extends Control

@onready var label1 = $Label
@onready var label2 = $Label2
@onready var label3 = $Label3

func _ready() -> void:
	# Apply outline to all labels
	add_outline_to_label(label1)
	add_outline_to_label(label2)
	add_outline_to_label(label3)

func add_outline_to_label(label: Label):
	# Quick outline - 4 directions
	var offsets = [
		Vector2(1, 0),   # Right
		Vector2(-1, 0),  # Left
		Vector2(0, 1),   # Down
		Vector2(0, -1)   # Up
	]
	
	for offset in offsets:
		var outline = label.duplicate()
		outline.modulate = Color.BLACK
		outline.position += offset * 1  # 2 pixel outline
		outline.z_index = label.z_index - 1
		add_child(outline)
	
	# Set main label color
	label.modulate = Color.WHITE  # Your text color
	label.z_index = 100  # Bring to front
"

