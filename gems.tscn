[ext_resource type="Texture2D" uid="uid://k6rw3wo2o5xe" path="res://Sunny Land Collection Files/Assets/Props Items and VFX/Sunnyland items/Spritesheets/gem.png" id="2_ooqnb"]

[sub_resource type="GDScript" id="GDScript_vcjm0"]
script/source = "extends Node2D

@onready var animated_sprite = $AnimatedSprite2D
@onready var area = $Area2D

var gem = 1  # How much diamond this gem gives

func _ready():
	# Play coin animation
	animated_sprite.play(\"Idle\")  # Change to your animation name
	
	# Connect the area signal
	area.body_entered.connect(_on_body_entered)

func _on_body_entered(body):
	if body.name == \"Player\":
		collect_gem(body)

func collect_gem(player):
	print(\"💎 Gem collected! Gem: \", Game.gem, \" → \", Game.gem + gem)
	
	# Add gold
	animated_sprite.play(\"Collect\")
	Game.gem += gem
	
	# Save game
	Utilities.saveGame()
	
	# Play sound effect
	AudioController.play_gem_collect()
	
	# Optional: Play collect animation/effect before disappearing
	await get_tree().create_timer(0.1).timeout
	
	# Remove coin
	queue_free()
"

